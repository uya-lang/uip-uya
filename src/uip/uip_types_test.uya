    uip_state.uip_buf[27] = 168 as byte;
    uip_state.uip_buf[28] = 0 as byte;
    uip_state.uip_buf[29] = 1 as byte;
    uip_state.uip_buf[30] = 192 as byte;
    uip_state.uip_buf[31] = 168 as byte;
    uip_state.uip_buf[32] = 0 as byte;
    uip_state.uip_buf[33] = 2 as byte;
    uip_state.uip_buf[34] = 0x20 as byte;
    uip_state.uip_buf[35] = 0x00 as byte;
    uip_state.uip_buf[36] = 0x10 as byte;
    uip_state.uip_buf[37] = 0x00 as byte;
    uip_state.uip_buf[38] = 0x00 as byte;
    uip_state.uip_buf[39] = 0x00 as byte;
    uip_state.uip_buf[40] = 0x00 as byte;
    uip_state.uip_buf[41] = 0x09 as byte;
    uip_state.uip_buf[42] = 0x00 as byte;
    uip_state.uip_buf[43] = 0x00 as byte;
    uip_state.uip_buf[44] = 0x00 as byte;
    uip_state.uip_buf[45] = 0x02 as byte;
    uip_state.uip_buf[46] = 0x50 as byte;
    uip_state.uip_buf[47] = 0x11 as byte;
    uip_state.uip_buf[48] = 0x02 as byte;
    uip_state.uip_buf[49] = 0x00 as byte;
    uip_state.uip_buf[50] = 0x00 as byte;
    uip_state.uip_buf[51] = 0x00 as byte;
    uip_state.uip_buf[52] = 0x00 as byte;
    uip_state.uip_buf[53] = 0x00 as byte;

    uip_input();

    try expect(uip_state.uip_conns[0].tcpstateflags == UipTcpState.Closing);
    try assert_eq_i32(uip_state.uip_conns[0].rcv_nxt[3] as i32, 3);
    try assert_eq_i32(uip_state.uip_len as i32, 54);
    try assert_eq_i32(uip_state.uip_buf[47] as i32, 0x10);
}

test "uip_input_ack_moves_closing_to_timewait" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
    uip_state.uip_conns[0] = UipConn{
        tcpstateflags: UipTcpState.Closing,
        timer: 0,
        nrtx: 0,
        lport: 0x1000u16,
        rport: 0x2000u16,
        ripaddr: uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte),
        snd_nxt: [0 as byte, 0 as byte, 0 as byte, 2 as byte],
        rcv_nxt: [0 as byte, 0 as byte, 0 as byte, 3 as byte],
        len: 0,
        mss: 512u16,
        initialmss: 512u16,
        appstate: 0,
    };

    uip_state.uip_len = 14 + 20 + 20;
    uip_state.uip_buf[12] = 0x08 as byte;
    uip_state.uip_buf[13] = 0x00 as byte;
    uip_state.uip_buf[14] = 0x45 as byte;
    uip_state.uip_buf[15] = 0x00 as byte;
    uip_state.uip_buf[16] = 0x00 as byte;
    uip_state.uip_buf[17] = 0x28 as byte;
    uip_state.uip_buf[22] = 64 as byte;
    uip_state.uip_buf[23] = 6 as byte;
    uip_state.uip_buf[26] = 192 as byte;
    uip_state.uip_buf[27] = 168 as byte;
    uip_state.uip_buf[28] = 0 as byte;
    uip_state.uip_buf[29] = 1 as byte;
    uip_state.uip_buf[30] = 192 as byte;
    uip_state.uip_buf[31] = 168 as byte;
    uip_state.uip_buf[32] = 0 as byte;
    uip_state.uip_buf[33] = 2 as byte;
    uip_state.uip_buf[34] = 0x20 as byte;
    uip_state.uip_buf[35] = 0x00 as byte;
    uip_state.uip_buf[36] = 0x10 as byte;
    uip_state.uip_buf[37] = 0x00 as byte;
    uip_state.uip_buf[42] = 0x00 as byte;
    uip_state.uip_buf[43] = 0x00 as byte;
    uip_state.uip_buf[44] = 0x00 as byte;
    uip_state.uip_buf[45] = 0x02 as byte;
    uip_state.uip_buf[46] = 0x50 as byte;
    uip_state.uip_buf[47] = 0x10 as byte;

    uip_input();

    try expect(uip_state.uip_conns[0].tcpstateflags == UipTcpState.TimeWait);
    try assert_eq_i32(uip_state.uip_conns[0].timer as i32, 0);
}

test "uip_poll_conn_synsent_sends_syn" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));

    const index: i32 = uip_connect(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte), 0x2000u16);
    try assert_eq_i32(index, 0);

    uip_poll_conn(0);

    try expect(uip_state.uip_conns[0].tcpstateflags == UipTcpState.SynSent);
    try assert_eq_i32(uip_state.uip_len as i32, 54);
    try assert_eq_i32(uip_state.uip_buf[23] as i32, 6);
    try assert_eq_i32(uip_state.uip_buf[34] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[35] as i32, 0x01);
    try assert_eq_i32(uip_state.uip_buf[36] as i32, 0x20);
    try assert_eq_i32(uip_state.uip_buf[37] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[47] as i32, 0x02);
    try assert_eq_i32(uip_state.uip_buf[41] as i32, 0x00);
}

test "uip_input_synack_moves_synsent_to_established_and_acks" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));

    const index: i32 = uip_connect(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte), 0x2000u16);
    try assert_eq_i32(index, 0);

    uip_state.uip_len = 14 + 20 + 20;
    uip_state.uip_buf[12] = 0x08 as byte;
    uip_state.uip_buf[13] = 0x00 as byte;
    uip_state.uip_buf[14] = 0x45 as byte;
    uip_state.uip_buf[15] = 0x00 as byte;
    uip_state.uip_buf[16] = 0x00 as byte;
    uip_state.uip_buf[17] = 0x28 as byte;
    uip_state.uip_buf[22] = 64 as byte;
    uip_state.uip_buf[23] = 6 as byte;
    uip_state.uip_buf[26] = 192 as byte;
    uip_state.uip_buf[27] = 168 as byte;
    uip_state.uip_buf[28] = 0 as byte;
    uip_state.uip_buf[29] = 1 as byte;
    uip_state.uip_buf[30] = 192 as byte;
    uip_state.uip_buf[31] = 168 as byte;
    uip_state.uip_buf[32] = 0 as byte;
    uip_state.uip_buf[33] = 2 as byte;
    uip_state.uip_buf[34] = 0x20 as byte;
    uip_state.uip_buf[35] = 0x00 as byte;
    uip_state.uip_buf[36] = 0x10 as byte;
    uip_state.uip_buf[37] = 0x01 as byte;
    uip_state.uip_buf[38] = 0x00 as byte;
    uip_state.uip_buf[39] = 0x00 as byte;
    uip_state.uip_buf[40] = 0x00 as byte;
    uip_state.uip_buf[41] = 0x05 as byte;
    uip_state.uip_buf[42] = 0x00 as byte;
    uip_state.uip_buf[43] = 0x00 as byte;
    uip_state.uip_buf[44] = 0x00 as byte;
    uip_state.uip_buf[45] = 0x01 as byte;
    uip_state.uip_buf[46] = 0x50 as byte;
