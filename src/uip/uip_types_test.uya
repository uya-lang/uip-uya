test "uip_input_ack_completes_three_way_handshake" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
    uip_state.uip_conns[0] = UipConn{
        tcpstateflags: UipTcpState.SynRcvd,
        timer: 0,
        nrtx: 0,
        lport: 0x1000u16,
        rport: 0x2000u16,
