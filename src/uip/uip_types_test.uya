    try assert_eq_i32(uip_state.uip_conns[0].rcv_nxt[3] as i32, 6);
    try assert_eq_i32(uip_state.uip_len as i32, 54);
    try assert_eq_i32(uip_state.uip_buf[47] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[41] as i32, 0x01);
