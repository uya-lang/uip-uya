use uip_conf.UIP_ARPTAB_SIZE;
use uip_conf.UIP_BUFSIZE;
use uip_conf.UIP_BUFSIZE_WITH_PADDING;
use uip_conf.UIP_CONNS;
use uip_conf.UIP_LISTENPORTS;
use uip_conf.UIP_LLH_LEN;
use uip_conf.UIP_IPH_LEN;
use uip_conf.UIP_TCPH_LEN;
use uip_conf.UIP_UDPH_LEN;
use uip_types.UipIpAddr;
use uip_types.UipEthAddr;
use uip_types.UipTcpState;
use uip_types.UipConn;
use uip_types.uip_ipaddr;
use uip_types.uip_ethaddr;
use uip_types.uip_tcp_appdata_offset;
use uip_types.uip_udp_appdata_offset;
use uip_core.uip_init;
use uip_core.uip_input;
use uip_core.uip_listen;
use uip_core.uip_poll_conn;
use uip_core.uip_close;
use uip_core.uip_unlisten;
use uip_core.uip_sethostaddr;
use uip_core.uip_udp_bind;
use uip_core.uip_udp_new;
use uip_core.uip_udp_periodic;
use uip_core.uip_send;
use uip_core.uip_send_at;
use uip_core.uip_state;
use uip_arp.uip_arp_arpin;
use uip_arp.uip_arp_init;
use uip_arp.uip_arp_ipin;
use uip_arp.uip_arp_out;
use uip_arp.uip_arp_state;
use uip_arp.uip_arp_timer;
use uip_arp.uip_arp_update;
use std.testing.assert_eq_i32;
use std.testing.expect;

test "uip_conf_constants_are_sane" {
    try expect(UIP_BUFSIZE > 0);
    try expect(UIP_BUFSIZE_WITH_PADDING == UIP_BUFSIZE + 2);
    try expect(UIP_CONNS > 0);
    try expect(UIP_LISTENPORTS > 0);
    try expect(UIP_ARPTAB_SIZE > 0);
}

test "uip_ipaddr_builder" {
    const ip: UipIpAddr = uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte);
    try assert_eq_i32(ip.addr[0] as i32, 0xc0a8);
    try assert_eq_i32(ip.addr[1] as i32, 0x0002);
}

test "uip_ethaddr_builder" {
    const mac: UipEthAddr = uip_ethaddr(1 as byte, 2 as byte, 3 as byte, 4 as byte, 5 as byte, 6 as byte);
    try assert_eq_i32(mac.addr[0] as i32, 1);
    try assert_eq_i32(mac.addr[5] as i32, 6);
}

test "uip_appdata_offsets" {
    try assert_eq_i32(uip_tcp_appdata_offset() as i32, (UIP_LLH_LEN + UIP_IPH_LEN + UIP_TCPH_LEN) as i32);
    try assert_eq_i32(uip_udp_appdata_offset() as i32, (UIP_LLH_LEN + UIP_IPH_LEN + UIP_UDPH_LEN) as i32);
}

test "uip_init_sets_default_addresses" {
    uip_init();
    try assert_eq_i32(uip_state.uip_hostaddr.addr[0] as i32, 0xc0a8);
    try assert_eq_i32(uip_state.uip_hostaddr.addr[1] as i32, 0x0002);
    try assert_eq_i32(uip_state.uip_draddr.addr[0] as i32, 0xc0a8);
    try assert_eq_i32(uip_state.uip_draddr.addr[1] as i32, 0x0001);
    try assert_eq_i32(uip_state.uip_netmask.addr[0] as i32, 0xffff);
    try assert_eq_i32(uip_state.uip_netmask.addr[1] as i32, 0xff00);
}

test "uip_listen_and_unlisten_manage_fixed_table" {
    uip_init();
    try expect(uip_listen(0x1234u16));
    try expect(uip_listen(0x1234u16));
    try assert_eq_i32(uip_state.uip_listenports[0] as i32, 0x1234);
    uip_unlisten(0x1234u16);
    try assert_eq_i32(uip_state.uip_listenports[0] as i32, 0);
}

test "uip_send_registers_intent_without_materializing_packet" {
    uip_init();
    uip_state.uip_buf[100] = 0xaa as byte;
    uip_state.uip_buf[101] = 0xbb as byte;
    try expect(uip_send_at(100usize, 2usize));
    try assert_eq_i32(uip_state.uip_send_offset as i32, 100);
    try assert_eq_i32(uip_state.uip_send_len as i32, 2);
    try assert_eq_i32(uip_state.uip_sappdata_offset as i32, 100);
    try assert_eq_i32(uip_state.uip_slen as i32, 2);
    try assert_eq_i32(uip_state.uip_len as i32, 0);
}

test "uip_poll_conn_materializes_registered_tcp_send" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
    uip_state.uip_conns[0] = UipConn{
        tcpstateflags: UipTcpState.Established,
        timer: 0,
        nrtx: 0,
        lport: 0x1000u16,
        rport: 0x2000u16,
        ripaddr: uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte),
        snd_nxt: [0 as byte, 0 as byte, 0 as byte, 1 as byte],
        rcv_nxt: [0 as byte, 0 as byte, 0 as byte, 8 as byte],
        len: 0,
        mss: 512u16,
        initialmss: 512u16,
        appstate: 0,
    };
    uip_state.uip_buf[54] = 0xde as byte;
    uip_state.uip_buf[55] = 0xad as byte;
    uip_state.uip_buf[56] = 0xbe as byte;
    try expect(uip_send_at(54usize, 3usize));

    uip_poll_conn(0usize);

    try assert_eq_i32(uip_state.uip_len as i32, 57);
    try assert_eq_i32(uip_state.uip_buf[47] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[54] as i32, 0xde);
    try assert_eq_i32(uip_state.uip_buf[55] as i32, 0xad);
    try assert_eq_i32(uip_state.uip_buf[56] as i32, 0xbe);
    try assert_eq_i32(uip_state.uip_conns[0].snd_nxt[3] as i32, 4);
    try assert_eq_i32(uip_state.uip_send_len as i32, 0);
}

test "uip_udp_periodic_materializes_registered_udp_send" {
    uip_init();
    try expect(uip_udp_bind(0usize, 0x1000u16, 0x2000u16, uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte)));
    uip_state.uip_buf[42] = 0xca as byte;
    uip_state.uip_buf[43] = 0xfe as byte;
    try expect(uip_send_at(42usize, 2usize));

    uip_udp_periodic(0usize);

    try assert_eq_i32(uip_state.uip_len as i32, 44);
    try assert_eq_i32(uip_state.uip_buf[23] as i32, 17);
    try assert_eq_i32(uip_state.uip_buf[34] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[35] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[36] as i32, 0x20);
    try assert_eq_i32(uip_state.uip_buf[37] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[42] as i32, 0xca);
    try assert_eq_i32(uip_state.uip_buf[43] as i32, 0xfe);
    try assert_eq_i32(uip_state.uip_send_len as i32, 0);
}

test "uip_input_replies_to_icmp_echo_for_hostaddr" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));

    uip_state.uip_len = 14 + 20 + 8;

    uip_state.uip_buf[0] = 0x02 as byte;
    uip_state.uip_buf[1] = 0x00 as byte;
    uip_state.uip_buf[2] = 0x00 as byte;
    uip_state.uip_buf[3] = 0x00 as byte;
    uip_state.uip_buf[4] = 0x00 as byte;
    uip_state.uip_buf[5] = 0x02 as byte;
    uip_state.uip_buf[6] = 0x10 as byte;
    uip_state.uip_buf[7] = 0x11 as byte;
    uip_state.uip_buf[8] = 0x12 as byte;
    uip_state.uip_buf[9] = 0x13 as byte;
    uip_state.uip_buf[10] = 0x14 as byte;
    uip_state.uip_buf[11] = 0x15 as byte;
    uip_state.uip_buf[12] = 0x08 as byte;
    uip_state.uip_buf[13] = 0x00 as byte;

    uip_state.uip_buf[14] = 0x45 as byte;
    uip_state.uip_buf[15] = 0x00 as byte;
    uip_state.uip_buf[16] = 0x00 as byte;
    uip_state.uip_buf[17] = 0x1c as byte;
    uip_state.uip_buf[18] = 0x12 as byte;
    uip_state.uip_buf[19] = 0x34 as byte;
    uip_state.uip_buf[20] = 0x00 as byte;
    uip_state.uip_buf[21] = 0x00 as byte;
    uip_state.uip_buf[22] = 64 as byte;
    uip_state.uip_buf[23] = 1 as byte;
    uip_state.uip_buf[24] = 0 as byte;
    uip_state.uip_buf[25] = 0 as byte;
    uip_state.uip_buf[26] = 192 as byte;
    uip_state.uip_buf[27] = 168 as byte;
    uip_state.uip_buf[28] = 0 as byte;
    uip_state.uip_buf[29] = 1 as byte;
    uip_state.uip_buf[30] = 192 as byte;
    uip_state.uip_buf[31] = 168 as byte;
    uip_state.uip_buf[32] = 0 as byte;
    uip_state.uip_buf[33] = 2 as byte;
    uip_state.uip_buf[24] = 0 as byte;
    uip_state.uip_buf[25] = 0 as byte;

    uip_state.uip_buf[34] = 8 as byte;
    uip_state.uip_buf[35] = 0 as byte;
    uip_state.uip_buf[36] = 0 as byte;
    uip_state.uip_buf[37] = 0 as byte;
    uip_state.uip_buf[38] = 0x12 as byte;
    uip_state.uip_buf[39] = 0x34 as byte;
    uip_state.uip_buf[40] = 0x00 as byte;
    uip_state.uip_buf[41] = 0x01 as byte;

    uip_input();

    try assert_eq_i32(uip_state.uip_len as i32, 42);
    try assert_eq_i32(uip_state.uip_buf[34] as i32, 0);
    try assert_eq_i32(uip_state.uip_buf[26] as i32, 192);
    try assert_eq_i32(uip_state.uip_buf[27] as i32, 168);
    try assert_eq_i32(uip_state.uip_buf[28] as i32, 0);
    try assert_eq_i32(uip_state.uip_buf[29] as i32, 2);
    try assert_eq_i32(uip_state.uip_buf[30] as i32, 192);
    try assert_eq_i32(uip_state.uip_buf[31] as i32, 168);
    try assert_eq_i32(uip_state.uip_buf[32] as i32, 0);
    try assert_eq_i32(uip_state.uip_buf[33] as i32, 1);
    try expect(!(uip_state.uip_buf[24] == 0 as byte && uip_state.uip_buf[25] == 0 as byte));
    try expect(!(uip_state.uip_buf[36] == 0 as byte && uip_state.uip_buf[37] == 0 as byte));
}

test "uip_input_matches_udp_conn_and_sets_appdata" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
    try expect(uip_udp_bind(0usize, 0x1000u16, 0x2000u16, uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte)));

    uip_state.uip_len = 14 + 20 + 8 + 4;

    uip_state.uip_buf[12] = 0x08 as byte;
    uip_state.uip_buf[13] = 0x00 as byte;

    uip_state.uip_buf[14] = 0x45 as byte;
    uip_state.uip_buf[15] = 0x00 as byte;
    uip_state.uip_buf[16] = 0x00 as byte;
    uip_state.uip_buf[17] = 0x20 as byte;
    uip_state.uip_buf[18] = 0x00 as byte;
    uip_state.uip_buf[19] = 0x01 as byte;
    uip_state.uip_buf[20] = 0x00 as byte;
    uip_state.uip_buf[21] = 0x00 as byte;
    uip_state.uip_buf[22] = 64 as byte;
    uip_state.uip_buf[23] = 17 as byte;
    uip_state.uip_buf[24] = 0 as byte;
    uip_state.uip_buf[25] = 0 as byte;
    uip_state.uip_buf[26] = 192 as byte;
    uip_state.uip_buf[27] = 168 as byte;
    uip_state.uip_buf[28] = 0 as byte;
    uip_state.uip_buf[29] = 1 as byte;
    uip_state.uip_buf[30] = 192 as byte;
    uip_state.uip_buf[31] = 168 as byte;
    uip_state.uip_buf[32] = 0 as byte;
    uip_state.uip_buf[33] = 2 as byte;

    uip_state.uip_buf[34] = 0x20 as byte;
    uip_state.uip_buf[35] = 0x00 as byte;
    uip_state.uip_buf[36] = 0x10 as byte;
    uip_state.uip_buf[37] = 0x00 as byte;
    uip_state.uip_buf[38] = 0x00 as byte;
    uip_state.uip_buf[39] = 0x0c as byte;
    uip_state.uip_buf[40] = 0x00 as byte;
    uip_state.uip_buf[41] = 0x00 as byte;
    uip_state.uip_buf[42] = 0xaa as byte;
    uip_state.uip_buf[43] = 0xbb as byte;
    uip_state.uip_buf[44] = 0xcc as byte;
    uip_state.uip_buf[45] = 0xdd as byte;

    uip_input();

    try assert_eq_i32(uip_state.uip_len as i32, 46);
    try assert_eq_i32(uip_state.uip_udp_conn_index, 0);
    try assert_eq_i32(uip_state.uip_conn_index, -1);
    try assert_eq_i32(uip_state.uip_appdata_offset as i32, 42);
    try assert_eq_i32(uip_state.uip_sappdata_offset as i32, 42);
}

test "uip_input_drops_unmatched_udp_packet" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
