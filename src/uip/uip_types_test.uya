    uip_state.uip_buf[39] = 0x08 as byte;
    uip_state.uip_buf[40] = 0x00 as byte;
    uip_state.uip_buf[41] = 0x00 as byte;

    uip_input();

    try assert_eq_i32(uip_state.uip_len as i32, 0);
}

test "uip_udp_send_builds_minimal_ipv4_udp_packet" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
    try expect(uip_udp_bind(0usize, 0x1000u16, 0x2000u16, uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte)));

    uip_state.uip_buf[42] = 0xde as byte;
    uip_state.uip_buf[43] = 0xad as byte;
    uip_state.uip_buf[44] = 0xbe as byte;
    uip_state.uip_buf[45] = 0xef as byte;
    try expect(uip_send_at(42usize, 4usize));
    uip_udp_periodic(0usize);

    try assert_eq_i32(uip_state.uip_len as i32, 46);
    try assert_eq_i32(uip_state.uip_appdata_offset as i32, 42);
    try assert_eq_i32(uip_state.uip_sappdata_offset as i32, 42);
    try assert_eq_i32(uip_state.uip_slen as i32, 4);
    try assert_eq_i32(uip_state.uip_buf[14] as i32, 0x45);
    try assert_eq_i32(uip_state.uip_buf[16] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[17] as i32, 0x20);
    try assert_eq_i32(uip_state.uip_buf[23] as i32, 17);
    try assert_eq_i32(uip_state.uip_buf[26] as i32, 192);
    try assert_eq_i32(uip_state.uip_buf[27] as i32, 168);
    try assert_eq_i32(uip_state.uip_buf[28] as i32, 0);
    try assert_eq_i32(uip_state.uip_buf[29] as i32, 2);
    try assert_eq_i32(uip_state.uip_buf[30] as i32, 192);
    try assert_eq_i32(uip_state.uip_buf[31] as i32, 168);
    try assert_eq_i32(uip_state.uip_buf[32] as i32, 0);
    try assert_eq_i32(uip_state.uip_buf[33] as i32, 1);
    try assert_eq_i32(uip_state.uip_buf[34] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[35] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[36] as i32, 0x20);
    try assert_eq_i32(uip_state.uip_buf[37] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[38] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[39] as i32, 0x0c);
    try assert_eq_i32(uip_state.uip_buf[40] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[41] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[42] as i32, 0xde);
    try assert_eq_i32(uip_state.uip_buf[43] as i32, 0xad);
    try assert_eq_i32(uip_state.uip_buf[44] as i32, 0xbe);
    try assert_eq_i32(uip_state.uip_buf[45] as i32, 0xef);
    try expect(!(uip_state.uip_buf[24] == 0 as byte && uip_state.uip_buf[25] == 0 as byte));
}

test "uip_arp_out_wraps_ip_packet_with_ethernet_header" {
    uip_init();
    uip_arp_init();
    try expect(uip_udp_bind(0usize, 0x1000u16, 0x2000u16, uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte)));
    try expect(uip_arp_update(
        uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte),
        uip_ethaddr(0x10 as byte, 0x11 as byte, 0x12 as byte, 0x13 as byte, 0x14 as byte, 0x15 as byte)
    ));

    uip_state.uip_buf[42] = 1 as byte;
    uip_state.uip_buf[43] = 2 as byte;
    try expect(uip_send_at(42usize, 2usize));
    uip_udp_periodic(0usize);
    try expect(uip_arp_out());

    try assert_eq_i32(uip_state.uip_buf[0] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[1] as i32, 0x11);
    try assert_eq_i32(uip_state.uip_buf[2] as i32, 0x12);
    try assert_eq_i32(uip_state.uip_buf[3] as i32, 0x13);
    try assert_eq_i32(uip_state.uip_buf[4] as i32, 0x14);
    try assert_eq_i32(uip_state.uip_buf[5] as i32, 0x15);
    try assert_eq_i32(uip_state.uip_buf[6] as i32, 0x02);
    try assert_eq_i32(uip_state.uip_buf[7] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[8] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[9] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[10] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[11] as i32, 0x02);
    try assert_eq_i32(uip_state.uip_buf[12] as i32, 0x08);
    try assert_eq_i32(uip_state.uip_buf[13] as i32, 0x00);
}

test "uip_arp_out_rewrites_to_arp_request_on_cache_miss" {
    uip_init();
    uip_arp_init();
    try expect(uip_udp_bind(0usize, 0x1000u16, 0x2000u16, uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte)));
    try expect(uip_send(0usize));
    uip_udp_periodic(0usize);

    try expect(uip_arp_out());
    try assert_eq_i32(uip_state.uip_len as i32, 42);
    try assert_eq_i32(uip_state.uip_buf[0] as i32, 0xff);
    try assert_eq_i32(uip_state.uip_buf[1] as i32, 0xff);
    try assert_eq_i32(uip_state.uip_buf[2] as i32, 0xff);
    try assert_eq_i32(uip_state.uip_buf[3] as i32, 0xff);
    try assert_eq_i32(uip_state.uip_buf[4] as i32, 0xff);
    try assert_eq_i32(uip_state.uip_buf[5] as i32, 0xff);
    try assert_eq_i32(uip_state.uip_buf[6] as i32, 0x02);
    try assert_eq_i32(uip_state.uip_buf[7] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[8] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[9] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[10] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[11] as i32, 0x02);
    try assert_eq_i32(uip_state.uip_buf[12] as i32, 0x08);
    try assert_eq_i32(uip_state.uip_buf[13] as i32, 0x06);
    try assert_eq_i32(uip_state.uip_buf[14] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[15] as i32, 0x01);
    try assert_eq_i32(uip_state.uip_buf[16] as i32, 0x08);
    try assert_eq_i32(uip_state.uip_buf[17] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[18] as i32, 0x06);
    try assert_eq_i32(uip_state.uip_buf[19] as i32, 0x04);
    try assert_eq_i32(uip_state.uip_buf[20] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[21] as i32, 0x01);
    try assert_eq_i32(uip_state.uip_buf[28] as i32, 192);
    try assert_eq_i32(uip_state.uip_buf[29] as i32, 168);
    try assert_eq_i32(uip_state.uip_buf[30] as i32, 0);
    try assert_eq_i32(uip_state.uip_buf[31] as i32, 2);
    try assert_eq_i32(uip_state.uip_buf[38] as i32, 192);
    try assert_eq_i32(uip_state.uip_buf[39] as i32, 168);
    try assert_eq_i32(uip_state.uip_buf[40] as i32, 0);
    try assert_eq_i32(uip_state.uip_buf[41] as i32, 1);
}

test "uip_arp_arpin_rewrites_request_for_host_to_reply" {
    uip_init();
    uip_arp_init();
    uip_state.uip_len = 42;

    uip_state.uip_buf[0] = 0xff as byte;
    uip_state.uip_buf[1] = 0xff as byte;
    uip_state.uip_buf[2] = 0xff as byte;
    uip_state.uip_buf[3] = 0xff as byte;
    uip_state.uip_buf[4] = 0xff as byte;
    uip_state.uip_buf[5] = 0xff as byte;
    uip_state.uip_buf[6] = 0x10 as byte;
    uip_state.uip_buf[7] = 0x11 as byte;
    uip_state.uip_buf[8] = 0x12 as byte;
    uip_state.uip_buf[9] = 0x13 as byte;
