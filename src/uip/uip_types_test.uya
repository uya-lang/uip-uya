    uip_state.uip_buf[12] = 0x08 as byte;
    uip_state.uip_buf[13] = 0x06 as byte;
    uip_state.uip_buf[14] = 0x00 as byte;
    uip_state.uip_buf[15] = 0x01 as byte;
    uip_state.uip_buf[16] = 0x08 as byte;
    uip_state.uip_buf[17] = 0x00 as byte;
    uip_state.uip_buf[18] = 0x06 as byte;
    uip_state.uip_buf[19] = 0x04 as byte;
    uip_state.uip_buf[20] = 0x00 as byte;
    uip_state.uip_buf[21] = 0x01 as byte;
    uip_state.uip_buf[22] = 0x10 as byte;
    uip_state.uip_buf[23] = 0x11 as byte;
    uip_state.uip_buf[24] = 0x12 as byte;
    uip_state.uip_buf[25] = 0x13 as byte;
    uip_state.uip_buf[26] = 0x14 as byte;
    uip_state.uip_buf[27] = 0x15 as byte;
    uip_state.uip_buf[28] = 192 as byte;
    uip_state.uip_buf[29] = 168 as byte;
    uip_state.uip_buf[30] = 0 as byte;
    uip_state.uip_buf[31] = 1 as byte;
    uip_state.uip_buf[32] = 0x00 as byte;
    uip_state.uip_buf[33] = 0x00 as byte;
    uip_state.uip_buf[34] = 0x00 as byte;
    uip_state.uip_buf[35] = 0x00 as byte;
    uip_state.uip_buf[36] = 0x00 as byte;
    uip_state.uip_buf[37] = 0x00 as byte;
