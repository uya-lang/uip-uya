test "uip_input_matches_listening_tcp_syn" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
    try expect(uip_listen(0x1000u16));

    uip_state.uip_len = 14 + 20 + 20;
    uip_state.uip_buf[12] = 0x08 as byte;
    uip_state.uip_buf[13] = 0x00 as byte;
    uip_state.uip_buf[14] = 0x45 as byte;
    uip_state.uip_buf[15] = 0x00 as byte;
    uip_state.uip_buf[16] = 0x00 as byte;
    uip_state.uip_buf[17] = 0x28 as byte;
    uip_state.uip_buf[18] = 0x00 as byte;
    uip_state.uip_buf[19] = 0x01 as byte;
    uip_state.uip_buf[20] = 0x00 as byte;
    uip_state.uip_buf[21] = 0x00 as byte;
    uip_state.uip_buf[22] = 64 as byte;
    uip_state.uip_buf[23] = 6 as byte;
    uip_state.uip_buf[24] = 0 as byte;
    uip_state.uip_buf[25] = 0 as byte;
    uip_state.uip_buf[26] = 192 as byte;
    uip_state.uip_buf[27] = 168 as byte;
    uip_state.uip_buf[28] = 0 as byte;
    uip_state.uip_buf[29] = 1 as byte;
    uip_state.uip_buf[30] = 192 as byte;
    uip_state.uip_buf[31] = 168 as byte;
    uip_state.uip_buf[32] = 0 as byte;
    uip_state.uip_buf[33] = 2 as byte;
    uip_state.uip_buf[34] = 0x20 as byte;
    uip_state.uip_buf[35] = 0x00 as byte;
    uip_state.uip_buf[36] = 0x10 as byte;
    uip_state.uip_buf[37] = 0x00 as byte;
    uip_state.uip_buf[38] = 0x00 as byte;
    uip_state.uip_buf[39] = 0x00 as byte;
    uip_state.uip_buf[40] = 0x00 as byte;
    uip_state.uip_buf[41] = 0x01 as byte;
    uip_state.uip_buf[42] = 0x00 as byte;
    uip_state.uip_buf[43] = 0x00 as byte;
    uip_state.uip_buf[44] = 0x00 as byte;
    uip_state.uip_buf[45] = 0x00 as byte;
    uip_state.uip_buf[46] = 0x50 as byte;
    uip_state.uip_buf[47] = 0x02 as byte;
    uip_state.uip_buf[48] = 0x02 as byte;
    uip_state.uip_buf[49] = 0x00 as byte;
    uip_state.uip_buf[50] = 0x00 as byte;
    uip_state.uip_buf[51] = 0x00 as byte;
    uip_state.uip_buf[52] = 0x00 as byte;
    uip_state.uip_buf[53] = 0x00 as byte;

    uip_input();

    try assert_eq_i32(uip_state.uip_conn_index, 0);
    try assert_eq_i32(uip_state.uip_udp_conn_index, -1);
    try expect(uip_state.uip_conns[0].tcpstateflags == UipTcpState.SynRcvd);
    try assert_eq_i32(uip_state.uip_conns[0].lport as i32, 0x1000);
    try assert_eq_i32(uip_state.uip_conns[0].rport as i32, 0x2000);
    try assert_eq_i32(uip_state.uip_conns[0].ripaddr.addr[0] as i32, 0xc0a8);
    try assert_eq_i32(uip_state.uip_conns[0].ripaddr.addr[1] as i32, 0x0001);
    try assert_eq_i32(uip_state.uip_buf[34] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[35] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[36] as i32, 0x20);
    try assert_eq_i32(uip_state.uip_buf[37] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[42] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[43] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[44] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[45] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[46] as i32, 0x50);
    try assert_eq_i32(uip_state.uip_buf[47] as i32, 0x12);
    try expect(!(uip_state.uip_buf[50] == 0 as byte && uip_state.uip_buf[51] == 0 as byte));
}

