test "uip_tcp_send_builds_ack_payload_and_advances_seq" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
    uip_state.uip_conns[0] = UipConn{
        tcpstateflags: UipTcpState.Established,
        timer: 0,
        nrtx: 0,
        lport: 0x1000u16,
        rport: 0x2000u16,
        ripaddr: uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte),
        snd_nxt: [0 as byte, 0 as byte, 0 as byte, 1 as byte],
        rcv_nxt: [0 as byte, 0 as byte, 0 as byte, 8 as byte],
        len: 0,
        mss: 512u16,
        initialmss: 512u16,
        appstate: 0,
    };
    uip_state.uip_conn_index = 0;
    uip_state.uip_buf[54] = 0xde as byte;
    uip_state.uip_buf[55] = 0xad as byte;
    uip_state.uip_buf[56] = 0xbe as byte;

    try expect(uip_send(3usize));
    uip_poll_conn(0usize);

    try assert_eq_i32(uip_state.uip_len as i32, 57);
    try assert_eq_i32(uip_state.uip_buf[23] as i32, 6);
    try assert_eq_i32(uip_state.uip_buf[34] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[35] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[36] as i32, 0x20);
    try assert_eq_i32(uip_state.uip_buf[37] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[42] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[43] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[44] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[45] as i32, 0x01);
    try assert_eq_i32(uip_state.uip_buf[46] as i32, 0x50);
    try assert_eq_i32(uip_state.uip_buf[47] as i32, 0x10);
    try assert_eq_i32(uip_state.uip_buf[50] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[51] as i32, 0x08);
    try assert_eq_i32(uip_state.uip_buf[54] as i32, 0xde);
    try assert_eq_i32(uip_state.uip_buf[55] as i32, 0xad);
    try assert_eq_i32(uip_state.uip_buf[56] as i32, 0xbe);
    try assert_eq_i32(uip_state.uip_conns[0].snd_nxt[3] as i32, 4);
}

test "uip_tcp_close_sends_fin_ack_and_moves_to_finwait1" {
    uip_init();
    uip_sethostaddr(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 2 as byte));
    uip_state.uip_conns[0] = UipConn{
        tcpstateflags: UipTcpState.Established,
        timer: 0,
        nrtx: 0,
        lport: 0x1000u16,
        rport: 0x2000u16,
        ripaddr: uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte),
        snd_nxt: [0 as byte, 0 as byte, 0 as byte, 1 as byte],
        rcv_nxt: [0 as byte, 0 as byte, 0 as byte, 8 as byte],
        len: 0,
        mss: 512u16,
        initialmss: 512u16,
        appstate: 0,
    };
    uip_state.uip_conn_index = 0;

    try expect(uip_close());
    uip_poll_conn(0usize);

    try expect(uip_state.uip_conns[0].tcpstateflags == UipTcpState.FinWait1);
    try assert_eq_i32(uip_state.uip_len as i32, 54);
    try assert_eq_i32(uip_state.uip_buf[23] as i32, 6);
    try assert_eq_i32(uip_state.uip_buf[47] as i32, 0x11);
    try assert_eq_i32(uip_state.uip_buf[42] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[43] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[44] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[45] as i32, 0x01);
    try assert_eq_i32(uip_state.uip_buf[50] as i32, 0x00);
    try assert_eq_i32(uip_state.uip_buf[51] as i32, 0x08);
    try assert_eq_i32(uip_state.uip_conns[0].snd_nxt[3] as i32, 2);
}

