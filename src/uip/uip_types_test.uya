test "uip_arp_timer_keeps_fresh_entry" {
    uip_init();
    uip_arp_init();
    try expect(uip_arp_update(
        uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte),
        uip_ethaddr(0x10 as byte, 0x11 as byte, 0x12 as byte, 0x13 as byte, 0x14 as byte, 0x15 as byte)
    ));

    uip_arp_timer();

    try assert_eq_i32(uip_arp_state.arp_table[0].ipaddr.addr[0] as i32, 0xc0a8);
    try assert_eq_i32(uip_arp_state.arp_table[0].ipaddr.addr[1] as i32, 0x0001);
    try assert_eq_i32(uip_arp_state.arp_table[0].ethaddr.addr[0] as i32, 0x10);
    try assert_eq_i32(uip_arp_state.arptime as i32, 1);
}

