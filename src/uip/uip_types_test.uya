test "uip_arp_timer_expires_old_entry" {
    uip_init();
    uip_arp_init();
    try expect(uip_arp_update(
        uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte),
        uip_ethaddr(0x10 as byte, 0x11 as byte, 0x12 as byte, 0x13 as byte, 0x14 as byte, 0x15 as byte)
    ));

    uip_arp_state.arptime = 119 as u8;
    uip_arp_state.arp_table[0].time = 0 as u8;
    uip_arp_timer();

    try assert_eq_i32(uip_arp_state.arptime as i32, 120);
    try assert_eq_i32(uip_arp_state.arp_table[0].ipaddr.addr[0] as i32, 0);
    try assert_eq_i32(uip_arp_state.arp_table[0].ipaddr.addr[1] as i32, 0);
    try assert_eq_i32(uip_arp_state.arp_table[0].ethaddr.addr[0] as i32, 0);
    try assert_eq_i32(uip_arp_state.arp_table[0].ethaddr.addr[5] as i32, 0);
}

test "uip_udp_new_allocates_first_free_slot" {
    uip_init();

    const idx: i32 = uip_udp_new(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte), 0x2000u16);
    try assert_eq_i32(idx, 0);
    try assert_eq_i32(uip_state.uip_udp_conns[0].ripaddr.addr[0] as i32, 0xc0a8);
    try assert_eq_i32(uip_state.uip_udp_conns[0].ripaddr.addr[1] as i32, 0x0001);
    try assert_eq_i32(uip_state.uip_udp_conns[0].rport as i32, 0x2000);
    try expect(uip_state.uip_udp_conns[0].lport != 0u16);
    try assert_eq_i32(uip_state.uip_udp_conns[0].ttl as i32, 64);
}

test "uip_udp_new_returns_minus_one_when_table_full" {
    uip_init();

    var i: usize = 0;
    while i < uip_conf.UIP_UDP_CONNS {
        const idx: i32 = uip_udp_new(uip_ipaddr(192 as byte, 168 as byte, 0 as byte, (1 + i) as byte), 0x2000u16 + (i as u16));
        try assert_eq_i32(idx, i as i32);
        i = i + 1;
    }

    const extra: i32 = uip_udp_new(uip_ipaddr(10 as byte, 0 as byte, 0 as byte, 1 as byte), 0x3000u16);
    try assert_eq_i32(extra, -1);
}

test "uip_udp_send_sets_nonzero_checksum" {
    uip_init();
    try expect(uip_udp_bind(0usize, 0x1000u16, 0x2000u16, uip_ipaddr(192 as byte, 168 as byte, 0 as byte, 1 as byte)));
    uip_state.uip_buf[42] = 0xde as byte;
    uip_state.uip_buf[43] = 0xad as byte;
    uip_state.uip_buf[44] = 0xbe as byte;
    uip_state.uip_buf[45] = 0xef as byte;

    try expect(uip_send_at(42usize, 4usize));
    uip_udp_periodic(0usize);
    try expect(!(uip_state.uip_buf[40] == 0 as byte && uip_state.uip_buf[41] == 0 as byte));
}

